* tl_lumped_equivalent_control
* Normalized LC transmission-line / waveguide-like 4->8->12 ladder.
* topology=tl_lumped_equivalent_control role=control
.options reltol=3e-4 abstol=1e-8 chgtol=1e-12 method=gear maxord=2

Cs0 s0 0 1
Lress0 s0 0 0.00158314349441
Rlosss0 s0 0 14.2857142857
Ls0_1 s0 s1 0.000677942380343
Cs1 s1 0 1
Lress1 s1 0 0.00158314349441
Rlosss1 s1 0 14.2857142857
Ls1_2 s1 s2 0.000677942380343
Cs2 s2 0 1
